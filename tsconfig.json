{
  "extends": "./src/config/typescript-next/tsconfig.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "paths": {
      "~/actions": ["./src/actions/index.ts"],
      "~/components/core/*": ["./src/components/core/*/index.ts"],
      "~/components/layouts/*": ["./src/components/layouts/*/index.ts"],
      "~/components/reset": ["./src/components/reset.css"],
      "~/components/templates": ["./src/components/templates/index.ts"],
      "~/constants": ["./src/constants/index.ts"],
      "~/facade": ["./src/facade/index.ts"],
      "~/schema/*": ["./src/schema/*/index.ts"],
      "~/types": ["./src/types/index.ts"],
      "~/utils": ["./src/utils/index.ts"],
      "~/services/*": ["./src/services/*/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "dist/types/**/*.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
